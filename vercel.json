{
  "buildCommand": "pnpm build --filter @workspace/for-yin",
  "outputDirectory": "artifacts/for-yin/dist/public",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
